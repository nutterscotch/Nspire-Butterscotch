# Toby Fox copyrighted game assets — do NOT commit. Each holds the original
# data.win + audio (and any cooked-nspire/ output derived from it). Engine code
# only; the user supplies their own assets locally.
DeltaCH2/
DeltaCH3/
DeltaCH4/
SURVEY_PROGRAM/
Undertale/

# Nspire build artifacts — regenerated by `make` under Ndless SDK. Broad
# wildcards catch sub-projects (runner/, engine_test/, hello/, render_test/).
*.o
*.elf
*.tns
*.zehn
obj/
nspire/runner/builds/

# Exception: the runner the web preprocessor bundles into every generated ZIP is
# a committed release asset, not a throwaway build artifact. Refresh it with
# `make -C nspire/runner engine.tns && cp nspire/runner/engine.tns <this path>`.
!preprocessor/processor-web/src/jsMain/resources/engine.tns

